# ============================================
# TG Downloader Bot - 配置文件
# ============================================

# === 运行模式: user | bot ===
RUN_MODE=user

# === Telegram API 凭证 (从 https://my.telegram.org 获取) ===
# 登录后 -> API Development tools -> 创建应用获取
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# === User 模式必需: Telethon 登录的手机号 ===
PHONE_NUMBER=+8612345678901

# === Bot 模式必需（当前用不到） ===
# BOT_TOKEN=

# === 你的主号 Telegram User ID ===
# 用途: 白名单校验、接收下载完成通知
# 获取方式: 启动后机器人会输出你的 ID，或用 @userinfobot
OWNER_USER_ID=

# === 监听的群 Chat ID ===
# 你、主号、副号都在这个群里
# 获取方式: 启动后机器人会在日志中输出所有对话的 ID
TARGET_GROUP_CHAT_ID=

# === 下载目录（容器内路径） ===
DOWNLOAD_BASE_PATH=/downloads

# === qBittorrent Web API 配置 ===
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin
