# ============================================
# TG Downloader Bot - 环境变量配置
# ============================================
# ⚠️ 注意：新版本推荐通过 Web 管理界面完成所有配置。
#    本文件仅用于首次容器启动时的初始引导。
#    配置保存后会写入 settings.json，之后无需编辑本文件。
# ============================================

# === 运行模式: user | bot ===
# RUN_MODE=user

# === Telegram API 凭证 (从 https://my.telegram.org 获取) ===
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=

# === User 模式必需: Telethon 登录的手机号 ===
# PHONE_NUMBER=+8612345678901

# === Bot 模式必需 ===
# BOT_TOKEN=

# === 你的主号 Telegram User ID ===
# OWNER_USER_ID=

# === 监听的群 Chat ID ===
# TARGET_GROUP_CHAT_ID=

# === 下载目录（容器内路径） ===
# DOWNLOAD_BASE_PATH=/downloads

# === qBittorrent Web API 配置 ===
# QBITTORRENT_URL=http://192.168.1.100:8080
# QBITTORRENT_USERNAME=admin
# QBITTORRENT_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
